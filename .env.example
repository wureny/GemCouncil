NEXT_PUBLIC_SPEECH_UNDERSTANDING_PROVIDER=mock

# Required when NEXT_PUBLIC_SPEECH_UNDERSTANDING_PROVIDER=gemma.
GEMMA_SPEECH_API_URL=http://127.0.0.1:8000

# Optional server-side secret for the remote Gemma speech service. Do not prefix with NEXT_PUBLIC.
GEMMA_SPEECH_API_KEY=
GEMMA_SPEECH_TIMEOUT_MS=45000

# Future remote TTS provider shape.
NEXT_PUBLIC_SPEECH_OUTPUT_PROVIDER=mock
VOXCPM_TTS_API_URL=http://127.0.0.1:8010
VOXCPM_TTS_API_KEY=
VOXCPM_TTS_TIMEOUT_MS=60000
